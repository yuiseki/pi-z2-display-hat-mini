# pi-z2 ターミナル用 bash 初期化ファイル (terminal.py が --rcfile で指定する)。
# 通常の ~/.bashrc を読み込んだ上で、小さな画面向けにプロンプト表示名だけ差し替える。

[ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc"

# 実ユーザ/ホスト名 (yuiseki@pi-z2-wh-2) に依らず、短い表示名にする。
# 色は ~/.bashrc の既定プロンプトと同じ (緑=名前 / 青=パス)。
PS1='\[\033[01;32m\]yui@pi-z2-2\[\033[00m\]:\[\033[01;34m\]\w \$\[\033[00m\] '
